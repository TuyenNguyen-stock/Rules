rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "chieuphuoc2005@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 150 &&
             data.role in ['admin', 'customer'] &&
             data.createdAt is string;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Read: Users can read their own profile, Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // Create: Users can create their own profile. Default role must be 'customer', unless they are the bootstrapped admin.
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       uidUnchanged() &&
                       (
                         request.resource.data.role == 'customer' || 
                         (request.resource.data.role == 'admin' && isAdmin())
                       );
                       
      // Update: Users can update their own profile (but not role), Admins can update roles.
      allow update: if isAuthenticated() && 
                       isValidUser(request.resource.data) && 
                       uidNotModified() &&
                       (
                         (isOwner(userId) && request.resource.data.role == resource.data.role) || 
                         isAdmin()
                       );
    }
  }
}
